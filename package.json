{
  "name": "aga-plus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "convex dev --env-file .env",
    "convex:sync": "node scripts/sync-convex-env.mjs",
    "convex:init": "convex dev --env-file .env --once && npm run convex:sync && npm run auth:setup",
    "dev:all": "npm run dev:convex & npm run dev",
    "auth:setup": "node scripts/setup-convex-auth-env.mjs --env-file .env",
    "convex:deploy": "convex deploy",
    "build": "next build",
    "build:prod": "convex deploy --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL --cmd 'next build'",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.80",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.25.2",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.525.0",
    "next": "^15.3.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
