# Convex ‚Äî run `npm run convex:sync` after `npm run dev:convex` to merge URLs here
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Local app URL (also pushed to Convex as SITE_URL via `npm run auth:setup`)
SITE_URL=http://localhost:3000

# Vercel only ‚Äî set these in Project Settings ‚Üí Environment Variables
# NEXT_PUBLIC_CONVEX_URL=
# NEXT_PUBLIC_CONVEX_SITE_URL=
# SITE_URL=https://your-app.vercel.app
# CONVEX_DEPLOY_KEY=  (optional ‚Äî only if build uses `npm run build:prod`)
