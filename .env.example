# Convex ‚Äî run `npm run convex:sync` after `npm run dev:convex` to merge URLs here
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Local app URL (also pushed to Convex as SITE_URL via `npm run auth:setup`)
SITE_URL=http://localhost:3000

# Optional ‚Äî not used by Convex Auth JWT flow
AUTH_SECRET=
